{
  "manifest_version": 3,
  "name": "Browser AI Agent",
  "version": "0.1.0",
  "description": "Turn any AI chat website into an AI programming agent",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [{
    "matches": [
      "https://chatgpt.com/*",
      "https://chat.openai.com/*",
      "https://claude.ai/*",
      "https://gemini.google.com/*",
      "https://chat.deepseek.com/*",
      "https://kimi.moonshot.cn/*",
      "https://www.doubao.com/*",
      "https://yuanbao.tencent.com/*"
    ],
    "js": ["content.js"],
    "run_at": "document_end"
  }]
}
